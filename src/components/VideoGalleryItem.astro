---
import { YouTube } from 'astro-embed';

export interface Props {
  videoId: string;
  title: string;
  description: string;
}

const { videoId, title, description } = Astro.props;
---

<article
  class="mb-6 transition intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
>
  <YouTube id={videoId} class="relative rounded mb-6" />

  <h3 class="text-xl sm:text-2xl font-bold leading-tight mb-2 font-heading dark:text-slate-300">
    {title}
  </h3>

  <p class="text-muted dark:text-slate-400 text-lg">{description}</p>
</article>
