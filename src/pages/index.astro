---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
//import Features2 from '~/components/widgets/Features2.astro';
//import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Brands from '~/components/widgets/Brands.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Huntington Robotics - Team 5016',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Join Us',
        href: 'mailto:huntingtonrobotics@gmail.com',
        target: '_blank',
        icon: 'tabler:thumb-up',
      },
      { text: 'Learn more', href: getPermalink('/about') },
    ]}
    image={{ src: '~/assets/images/profile.png', alt: 'Huntington Robotics Logo' }}
    imageLight={{ src: '~/assets/images/profile.png', alt: 'Huntington Robotics Logo' }}
  >
    <Fragment slot="title">
      Invested in Leadership, Engineering and Diversity
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Huntington Robotics - <span class="mb-1  font-bold text-blue-600">Team 5016</span> - is a high school robotics team participating
        in FIRST Robotics competitions.</span
      >
      We provide opportunities for students to gain experience in STEM and develop business and professional skills. 
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <!-- <Note /> -->

  <!-- Brands Widget ****************** -->

  <Brands
    id="sponsors"
    title="Sponsors"
    subtitle="Thank you for the continued support from our sponsors!"
    icons={[]}
    images={[
      {
        src: '~/assets/images/sponsors/Gellerman-300px.png',
        alt: 'Gellerman Orthodontics',
      },
      {
        src: '~/assets/images/sponsors/zebra4.png',
        alt: 'Zebra',
      },
      {
        src: '~/assets/images/sponsors/lanzwhite.png',
        alt: 'Signature Premier - Maria Lanzisero',
      },
      {
        src: '~/assets/images/sponsors/LuHi-300px.png',
        alt: 'LuHi Summer Camps',
      },      
      {
        src: '~/assets/images/sponsors/rotarywhite.png',
        alt: 'Rotary Club',
      },
      {
        src: '~/assets/images/sponsors/cdfwhite.png',
        alt: 'CDFS Law',
      },
      {
        src: '~/assets/images/sponsors/jrswhite.png',
        alt: 'JRS Precision',
      },      
      {
        src: '~/assets/images/sponsors/palacioswebsitewhite.png',
        alt: 'Palacios Law Group',
      },      
      {
        src: '~/assets/images/sponsors/GSG.png',
        alt: 'Injury Lawyers LI',
      },
    ]}
  />

